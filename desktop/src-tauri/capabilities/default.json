{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AskSQL Studio local desktop window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{
        "name": "binaries/asksql-server",
        "sidecar": true,
        "args": ["ui", "--no-open"]
      }]
    }
  ]
}
